{
  "expo": {
    "name": "RouteFloww",
    "slug": "app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo9.png",
    "scheme": "app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo9.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "RouteFloww uses Face ID to secure your account and protect your delivery data.",
        "NSSpeechRecognitionUsageDescription": "Allow RouteFloww to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow RouteFloww to use the microphone."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo9.png",
        "backgroundImage": "./assets/images/logo9.png",
        "monochromeImage": "./assets/images/logo9.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.vvdevill.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo9.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/logo9.png",
            "imageWidth": 76
          }
        }
      ],
      "./node_modules/@maplibre/maplibre-react-native/app.plugin.js",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow RouteFloww to use your location."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow RouteFloww to use the microphone.",
          "speechRecognitionPermission": "Allow RouteFloww to use speech recognition.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "RouteFloww uses Face ID to secure your account."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableBundleCompression": true
          }
        }
      ],
      "expo-secure-store",
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da6e074b-2c2f-405b-9e3e-3468536d474a"
      }
    },
    "owner": "saatvik_142"
  }
}
